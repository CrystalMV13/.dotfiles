%
% Create Problem Sections
%

\newcommand{\enterProblemHeader}[1]{
    \nobreak\extramarks{}{Problem \arabic{#1} continued on next page\ldots}\nobreak{}
    \nobreak\extramarks{Problem \arabic{#1} (continued)}{Problem \arabic{#1} continued on next page\ldots}\nobreak{}
}

\newcommand{\exitProblemHeader}[1]{
    \nobreak\extramarks{Problem \arabic{#1} (continued)}{Problem \arabic{#1} continued on next page\ldots}\nobreak{}
    \stepcounter{#1}
    \nobreak\extramarks{Problem \arabic{#1}}{}\nobreak{}
}

\newcommand{\enterSubpartHeader}[2]{
    \nobreak\extramarks{}{Problem \arabic{#1}.\Alph{#2} continued on next page\ldots}\nobreak{}
    \nobreak\extramarks{Problem \arabic{#1}.\Alph{#2} (continued)}{Problem \arabic{#1}.\Alph{#2} continued on next page\ldots}\nobreak{}
}

\newcommand{\exitSubpartHeader}[2]{
    \nobreak\extramarks{Problem \arabic{#1}.\Alph{#2} (continued)}{Problem \arabic{#1}.\Alph{#2} continued on next page\ldots}\nobreak{}
    \stepcounter{#2}
    \nobreak\extramarks{Problem \arabic{#1}}{}\nobreak{}
}

\setcounter{secnumdepth}{0}
\newcounter{partCounter}
\newcounter{problemCounter}
\setcounter{problemCounter}{1}
\nobreak\extramarks{Problem \arabic{problemCounter}}{}\nobreak{}

%
% Answers
%
\newcommand{\answer}[1]{
    \section{Answer #1}
}
\newcommand{\answerpart}[1]{
    \subsection{#1)}
}


%
% Homework Problem Environment
%
% This environment takes an optional argument. When given, it will adjust the
% problem counter. This is useful for when the problems given for your
% assignment aren't sequential. See the last 3 problems of this template for an
% example.
%
\newenvironment{problem}[1][-1]{
    \ifnum#1>0
        \setcounter{problemCounter}{#1}
    \fi
    \section{Problem \arabic{problemCounter}}
    \setcounter{partCounter}{1}
    \enterProblemHeader{problemCounter}
}{
    \exitProblemHeader{problemCounter}
}

\newenvironment{subpart}[1][-1]{
    \ifnum#1>0
        \setcounter{partCounter}{#1}
    \fi
    \subsection{\Alph{partCounter})}
    \enterSubpartHeader{problemCounter}{partCounter}
}{
    \exitSubpartHeader{problemCounter}{partCounter}
}

