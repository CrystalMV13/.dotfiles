% Set value
\newcommand{\setval}[3][\empty]{
    \ifx#1\empty
        \pgfkeyssetvalue{/variablenames/#2}{#2}
        \pgfkeyssetvalue{/variables/#2}{#3}
    \else
        \pgfkeyssetvalue{/variablenames/#1}{#2}
        \pgfkeyssetvalue{/variables/#1}{#3}
    \fi
}
\newcommand{\val}[1]{
    \pgfkeysvalueof{/variables/#1}
    % \pgfkeysifdefined{
    %     /variables/#1
    % }{
    %     \val{#1}
    % }{
    %     \textbf{\hl{EMPTY VALUE!!!}}
    % }
}
